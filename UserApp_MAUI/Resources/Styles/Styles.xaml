<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="DeepDark">#0F0F0F</Color>
    <Color x:Key="GlassPanel">#142B2B2B</Color>
    <Color x:Key="GlassStroke">#50FFFFFF</Color>
    <Color x:Key="GlassTint">#18FFFFFF</Color>
    <Color x:Key="GlassText">#F2F2F2</Color>
    <Color x:Key="GlassSubtext">#B8B8B8</Color>
    <Color x:Key="StatusSuccess">#4CAF50</Color>
    <Color x:Key="StatusWarning">#FBC02D</Color>
    <Color x:Key="StatusDanger">#E53935</Color>

    <Style x:Key="GlassCardStyle" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource GlassPanel}" />
        <Setter Property="Stroke" Value="{StaticResource GlassStroke}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 24" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="GlassAccentLabel" TargetType="Label">
        <Setter Property="BackgroundColor" Value="{StaticResource GlassTint}" />
        <Setter Property="TextColor" Value="{StaticResource GlassText}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

    <Style x:Key="GlassSearchStyle" TargetType="SearchBar">
        <Setter Property="BackgroundColor" Value="{StaticResource GlassPanel}" />
        <Setter Property="TextColor" Value="{StaticResource GlassText}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource GlassSubtext}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <Style x:Key="GlassHeadline" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource GlassText}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <Style x:Key="GlassSubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource GlassSubtext}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource GlassText}" />
        <Setter Property="BackgroundColor" Value="#262626" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="14,10" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{StaticResource StatusSuccess}" />
    </Style>

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource DeepDark}" />
    </Style>

</ResourceDictionary>
