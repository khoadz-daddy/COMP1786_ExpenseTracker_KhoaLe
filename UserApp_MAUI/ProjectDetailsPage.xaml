<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ExpenseTrackerUser"
             x:Class="ExpenseTrackerUser.ProjectDetailsPage"
             x:Name="ProjectDetailsRoot"
             x:DataType="local:ProjectDetailsViewModel"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False">
    
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" TextOverride="" />
    </Shell.BackButtonBehavior>

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="BackgroundGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0F172A" Offset="0.0" />
            <GradientStop Color="#0F172A" Offset="1.0" />
        </LinearGradientBrush>

        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="#1AFFFFFF" />
            <Setter Property="Stroke" Value="#33FFFFFF" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 16" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="Label">
            <Setter Property="TextColor" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontAttributes" Value="Bold" />
        </Style>

        <Style x:Key="DataLabel" TargetType="Label">
            <Setter Property="TextColor" Value="#94A3B8" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </ContentPage.Resources>

    <Grid Background="{StaticResource BackgroundGradient}" RowDefinitions="Auto,*">

        <!-- Modern custom header -->
        <Border Grid.Row="0"
                BackgroundColor="Transparent"
                Stroke="Transparent"
                StrokeThickness="0"
                Padding="16,12,16,14"
                Margin="0">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" VerticalOptions="Center">
                <!-- Back button -->
                <Button Grid.Column="0"
                        Text="←"
                        Command="{Binding GoBackCommand}"
                        BackgroundColor="#28FFFFFF"
                        TextColor="#FFFFFF"
                        FontSize="20"
                        CornerRadius="22"
                        WidthRequest="44"
                        HeightRequest="44"
                        Padding="0"
                        VerticalOptions="Center" />

                <!-- Title block -->
                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="{Binding Project.Name}"
                           TextColor="#F8FAFC"
                           FontSize="17"
                           FontAttributes="Bold"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />
                    <Label Text="Project Details"
                           TextColor="#94A3B8"
                           FontSize="12" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Scrollable content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,14,16,24" Spacing="14">

                <!-- Project summary card -->
                <Border Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="14">

                        <!-- Name / Status row -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Label Text="{Binding Project.StatusIcon}" FontSize="24" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="{Binding Project.Name}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#F8FAFC"
                                       VerticalOptions="Center"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding Project.ProjectCode, StringFormat='Code: {0}'}"
                                       TextColor="#94A3B8"
                                       FontSize="12" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="6">
                                <Border BackgroundColor="#22F2C94C"
                                        Stroke="#50F2C94C"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        Padding="8,4"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding Project.RiskLabel}"
                                           TextColor="#F2C94C"
                                           FontSize="12"
                                           FontAttributes="Bold" />
                                </Border>
                                <Button Text="{Binding Project.FavoriteLabel}"
                                        Command="{Binding ToggleFavoriteCommand}"
                                        BackgroundColor="#1E293B"
                                        TextColor="#F8FAFC"
                                        CornerRadius="12"
                                        HeightRequest="36"
                                        Padding="10,0"
                                        FontSize="11" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Description -->
                        <Label Text="{Binding Project.Description}"
                               FontSize="14"
                               TextColor="#94A3B8"
                               LineBreakMode="WordWrap" />

                        <!-- Status chip + Date -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Border BackgroundColor="#1E293B"
                                    Stroke="#334155"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="10,5">
                                <Label Text="{Binding Project.StatusLabel}"
                                       TextColor="#F8FAFC"
                                       FontSize="13" />
                            </Border>
                            <Label Grid.Column="1"
                                   Text="{Binding Project.DisplayDate, StringFormat='📅 {0}'}"
                                   TextColor="#94A3B8"
                                   FontSize="13"
                                   VerticalOptions="Center"
                                   HorizontalOptions="End" />
                        </Grid>

                        <!-- Manager -->
                        <Label Text="{Binding Project.Manager, StringFormat='👤 Manager: {0}'}"
                               Style="{StaticResource DataLabel}" />
                        <Label Text="{Binding Project.ClientInfo, StringFormat='🏢 Client/Department: {0}'}"
                               Style="{StaticResource DataLabel}" />
                        <Label Text="{Binding Project.SpecialRequirements, StringFormat='🧰 Special requirements: {0}'}"
                               Style="{StaticResource DataLabel}" />

                        <BoxView HeightRequest="1" BackgroundColor="#22FFFFFF" />

                        <!-- Budget breakdown -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border BackgroundColor="#1AFB923C" Stroke="#30FB923C" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16" Padding="12,10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="SPENT" TextColor="#94A3B8" FontSize="11" />
                                    <Label Text="{Binding Project.TotalSpent, StringFormat='{0:C0}'}"
                                           TextColor="#FB923C" FontSize="18" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1"
                                    BackgroundColor="#1AEF4444" Stroke="#30EF4444" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16" Padding="12,10">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="REMAINING" TextColor="#94A3B8" FontSize="11" />
                                    <Label Text="{Binding Project.RemainingBudget, StringFormat='{0:C0}'}"
                                           TextColor="#EF4444" FontSize="18" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Progress bar -->
                        <ProgressBar Progress="{Binding Project.Progress}"
                                     ProgressColor="{Binding Project.ProgressColor}"
                                     HeightRequest="8"
                                     Margin="0,4,0,0" />
                        <Label Text="{Binding Project.BudgetStatus}"
                               TextColor="{Binding Project.ProgressColor}"
                               FontSize="13"
                               FontAttributes="Bold" />

                        <!-- Export button -->
                        <Button Text="⬆  Export Expenses to CSV"
                                Command="{Binding ExportToCsvCommand}"
                                BackgroundColor="#38BDF8"
                                TextColor="#0F172A"
                                CornerRadius="16"
                                HeightRequest="60"
                                Padding="16,0"
                                FontAttributes="Bold"
                                Margin="0,4,0,0" />
                    </VerticalStackLayout>
                </Border>

                <!-- Expense details card -->
                <Border Style="{StaticResource GlassCard}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Expense Details"
                                   Style="{StaticResource SectionTitle}" VerticalOptions="Center" />
                            <Button Grid.Column="1" Text="+ Add" Command="{Binding AddExpenseCommand}"
                                    BackgroundColor="#38BDF8" TextColor="#0F172A" HeightRequest="60"
                                    CornerRadius="16" Padding="20,0" VerticalOptions="Center" FontAttributes="Bold" />
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#22FFFFFF" />

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Project.ExpenseList}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="local:Expense">
                                    <SwipeView>
                                        <SwipeView.LeftItems>
                                                <SwipeItems>
                                                <SwipeItem Text="Edit" BackgroundColor="#2196F3"
                                                           Command="{Binding Source={x:Reference ProjectDetailsRoot}, Path=BindingContext.EditExpenseCommand}"
                                                           CommandParameter="{Binding .}" />
                                            </SwipeItems>
                                        </SwipeView.LeftItems>
                                        <SwipeView.RightItems>
                                            <SwipeItems>
                                                <SwipeItem Text="Delete" BackgroundColor="#F44336"
                                                           Command="{Binding Source={x:Reference ProjectDetailsRoot}, Path=BindingContext.DeleteExpenseCommand}"
                                                           CommandParameter="{Binding .}" />
                                            </SwipeItems>
                                        </SwipeView.RightItems>
                                        <Border BackgroundColor="#1AFFFFFF"
                                                Stroke="#33FFFFFF"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 16"
                                                Padding="14,12">
                                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                                <Label Text="{Binding Description}"
                                                       TextColor="#F8FAFC"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       LineBreakMode="WordWrap" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding DisplayAmount}"
                                                       TextColor="#FB923C"
                                                       FontSize="15"
                                                       FontAttributes="Bold"
                                                       HorizontalOptions="End" />
                                                <Label Grid.Row="1" Grid.ColumnSpan="2"
                                                       Text="{Binding DisplayDate}"
                                                       TextColor="#94A3B8"
                                                       FontSize="12"
                                                       Margin="0,4,0,0" />
                                                <Label Grid.Row="2" Grid.ColumnSpan="2"
                                                       Text="{Binding DisplayStatus}"
                                                       TextColor="#94A3B8"
                                                       FontSize="12" />
                                                <Label Grid.Row="3" Grid.ColumnSpan="2"
                                                       Text="{Binding DisplayMeta}"
                                                       TextColor="#94A3B8"
                                                       FontSize="12" />
                                                <Label Grid.Row="4" Grid.ColumnSpan="2"
                                                       Text="{Binding DisplayOwner}"
                                                       TextColor="#94A3B8"
                                                       FontSize="12" />
                                            </Grid>
                                        </Border>
                                    </SwipeView>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Empty state -->
                        <VerticalStackLayout IsVisible="{Binding HasNoExpenses}"
                                             HorizontalOptions="Center"
                                             Spacing="8"
                                             Padding="20">
                            <Label Text="📭" FontSize="40" HorizontalOptions="Center" />
                            <Label Text="No expenses recorded yet"
                                   TextColor="#666666"
                                   FontSize="15"
                                   HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
