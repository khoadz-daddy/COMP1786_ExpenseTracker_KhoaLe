<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/project_admin"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_gravity="start"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/create_entry_desc"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp"/>

        <!-- Glassmorphism Card 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/general_info"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/accent_blue"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etProjectCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/glass_border"
                android:hint="@string/project_code_hint"
                android:importantForAutofill="no"
                android:inputType="textCapCharacters"
                android:minHeight="48dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                tools:targetApi="o" />

            <EditText
                android:id="@+id/etProjectName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_border"
                android:hint="@string/project_name_hint"
                android:importantForAutofill="no"
                android:inputType="textCapWords"
                android:minHeight="48dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                tools:targetApi="o" />

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_border"
                android:hint="@string/description_hint"
                android:importantForAutofill="no"
                android:inputType="text"
                android:minHeight="48dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                tools:targetApi="o" />

            <EditText
                android:id="@+id/etManager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_border"
                android:hint="@string/manager_name_hint"
                android:importantForAutofill="no"
                android:inputType="textPersonName"
                android:minHeight="48dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                tools:targetApi="o" />

            <EditText
                android:id="@+id/etSpecialRequirements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_border"
                android:hint="@string/special_requirements_hint"
                android:importantForAutofill="no"
                android:inputType="textMultiLine"
                android:minHeight="48dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                tools:targetApi="o" />

            <EditText
                android:id="@+id/etClientInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_border"
                android:hint="@string/client_info_hint"
                android:importantForAutofill="no"
                android:inputType="text"
                android:minHeight="48dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                tools:targetApi="o" />
        </LinearLayout>

        <!-- Glassmorphism Card 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/finance_status"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/accent_green"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etBudget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/glass_border"
                android:hint="@string/budget_hint"
                android:importantForAutofill="no"
                android:inputType="numberDecimal"
                android:minHeight="48dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                tools:targetApi="o" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/project_status"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="12dp"/>

            <Spinner
                android:id="@+id/spStatus"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:entries="@array/status_options"
                android:backgroundTint="@color/text_primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/risk_assessment"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:layout_marginTop="12dp"/>

            <Spinner
                android:id="@+id/spRiskAssessment"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:entries="@array/risk_options"
                android:backgroundTint="@color/text_primary"/>
        </LinearLayout>

        <!-- Glassmorphism Card 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card_bg"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/timeline"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/accent_orange"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etStartDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/glass_border"
                android:clickable="true"
                android:focusable="true"
                android:hint="@string/start_date_hint"
                android:importantForAutofill="no"
                android:inputType="none"
                android:minHeight="48dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                tools:targetApi="o"
                tools:ignore="TextFields" />

            <EditText
                android:id="@+id/etEndDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="@color/glass_border"
                android:clickable="true"
                android:focusable="true"
                android:hint="@string/end_date_hint"
                android:importantForAutofill="no"
                android:inputType="none"
                android:minHeight="48dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                tools:ignore="TextFields"
                tools:targetApi="o" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/deploy_project"
            android:backgroundTint="@color/accent_blue"
            android:textColor="@color/dark_bg"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            app:cornerRadius="16dp"
            tools:ignore="VisualLintButtonSize" />

        <Button
            android:id="@+id/btnViewList"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/open_database"
            android:backgroundTint="@color/glass_white"
            android:textColor="@color/text_primary"
            app:cornerRadius="16dp"
            app:strokeColor="@color/glass_border"
            app:strokeWidth="1dp"
            android:layout_marginBottom="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <Button
            android:id="@+id/btnSync"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/cloud_sync"
            android:backgroundTint="@color/accent_orange"
            android:textColor="@color/dark_bg"
            app:cornerRadius="16dp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnResetDb"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:text="@string/reset_database"
            android:backgroundTint="#EF4444"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            app:cornerRadius="16dp" />

    </LinearLayout>
</ScrollView>
