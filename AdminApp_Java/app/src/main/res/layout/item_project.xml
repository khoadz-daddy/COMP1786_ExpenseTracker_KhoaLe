<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_card_bg"
    android:padding="16dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="8dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/tvProjectCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PROJ-001"
            android:textColor="@color/accent_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvProjectName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvProjectCode"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvManager"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvProjectName"
            android:text="@string/manager_name_hint"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="@string/active"
            android:textColor="@color/accent_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/glass_white"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">
        <TextView
            android:id="@+id/tvBudget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/zero_amount"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>
        <TextView
            android:id="@+id/tvStartDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/start_date_hint"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Thanh tiến độ ngân sách thực tế -->
    <TextView
        android:id="@+id/tvUsageInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/usage_label_short"
        android:textColor="@color/accent_blue"
        android:textSize="11sp"
        android:layout_marginBottom="4dp"/>
    <ProgressBar
        android:id="@+id/pbBudget"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:progress="40"
        android:progressDrawable="@android:drawable/progress_horizontal"
        android:progressTint="@color/accent_blue"/>

</LinearLayout>
