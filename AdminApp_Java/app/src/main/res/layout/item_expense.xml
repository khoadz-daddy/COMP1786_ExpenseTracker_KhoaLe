<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_card_bg"
    android:padding="16dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvExpenseName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/expense_name"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="@string/pending_status"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:background="@drawable/glass_white"/>
    </RelativeLayout>

    <TextView
        android:id="@+id/tvExpenseType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/type_label"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="2dp"/>

    <TextView
        android:id="@+id/tvAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/zero_amount"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/accent_orange"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/date_label"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvClaimant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👤 Claimant: -"
        android:textSize="12sp"
        android:textColor="@color/text_primary"
        android:layout_marginTop="4dp"/>

    <TextView
        android:id="@+id/tvLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📍 Location: -"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="2dp"/>

</LinearLayout>