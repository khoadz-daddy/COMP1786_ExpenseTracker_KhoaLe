<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/dark_bg"
    android:padding="16dp">

    <!-- HEADER WITH BACK BUTTON -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerVertical="true"
            android:background="@drawable/glass_white"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary"
            android:contentDescription="@string/back" />

        <TextView
            android:id="@+id/tvProjectHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/manage_expenses"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnSyncDetail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/glass_white"
            android:src="@android:drawable/stat_notify_sync"
            app:tint="@color/text_primary"
            android:contentDescription="Sync" />
    </RelativeLayout>

    <!-- CARD INPUT AREA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/glass_card_bg"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etExpenseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:hint="@string/expense_name_hint"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/glass_border"
            android:layout_marginBottom="8dp"
            android:inputType="text"
            android:importantForAutofill="no"
            tools:targetApi="o" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <EditText
                android:id="@+id/etExpenseAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/amount_hint"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:backgroundTint="@color/glass_border"
                android:importantForAutofill="no" />
            <Spinner
                android:id="@+id/spCurrency"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="0.8"
                android:entries="@array/currency_options"
                android:backgroundTint="@color/text_primary"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etExpenseDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:hint="Date (dd/MM/yyyy) *"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/glass_border"
            android:layout_marginBottom="8dp"
            android:focusable="false"
            android:clickable="true"
            android:drawableEnd="@android:drawable/ic_menu_my_calendar"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/etClaimant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:hint="@string/claimant_hint"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/glass_border"
            android:layout_marginBottom="8dp"
            android:inputType="textPersonName"
            android:importantForAutofill="no" />

        <EditText
            android:id="@+id/etLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            android:hint="@string/location_hint"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:backgroundTint="@color/glass_border"
            android:layout_marginBottom="12dp"
            android:inputType="text"
            android:importantForAutofill="no" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/type_label"
                    android:textColor="@color/accent_blue"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"/>
                <Spinner
                    android:id="@+id/spExpenseType"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:entries="@array/expense_types"
                    android:backgroundTint="@color/text_primary"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/method_label"
                    android:textColor="@color/accent_blue"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"/>
                <Spinner
                    android:id="@+id/spPaymentMethod"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:entries="@array/method_options"
                    android:backgroundTint="@color/text_primary"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Payment Status"
            android:textColor="@color/accent_blue"
            android:textSize="12sp"
            android:layout_marginStart="8dp"/>
        <Spinner
            android:id="@+id/spPaymentStatus"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:entries="@array/payment_statuses"
            android:backgroundTint="@color/text_primary"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnAddExpense"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="4dp"
            android:text="@string/add_expense"
            android:backgroundTint="@color/accent_orange"
            android:textColor="@color/dark_bg"
            android:textStyle="bold"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/project_expenses"
        android:textStyle="bold"
        android:padding="8dp"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"/>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewExpenses"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:scrollbars="vertical"/>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>