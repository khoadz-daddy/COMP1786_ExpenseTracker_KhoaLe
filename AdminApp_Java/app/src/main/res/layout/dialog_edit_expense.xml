<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/dark_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expense Description"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/accent_blue"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etEditExpName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/glass_border"
        android:hint="e.g. Construction Materials"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:minHeight="48dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expense Type"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spEditExpType"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:entries="@array/expense_types"
        android:backgroundTint="@color/text_primary"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/amount_title"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/accent_green"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <EditText
            android:id="@+id/etEditExpAmount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@color/glass_border"
            android:inputType="numberDecimal"
            android:textColor="@color/text_primary"
            android:minHeight="48dp" />
        <Spinner
            android:id="@+id/spEditExpCurrency"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:entries="@array/currency_options"
            android:backgroundTint="@color/text_primary"/>
    </LinearLayout>

    <EditText
        android:id="@+id/etEditExpDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/glass_border"
        android:hint="Date (dd/MM/yyyy) *"
        android:textColor="@color/text_primary"
        android:focusable="false"
        android:clickable="true"
        android:drawableEnd="@android:drawable/ic_menu_my_calendar"
        android:minHeight="48dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etEditExpClaimant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/glass_border"
        android:hint="@string/claimant_hint"
        android:textColor="@color/text_primary"
        android:minHeight="48dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etEditExpLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/glass_border"
        android:hint="@string/location_hint"
        android:textColor="@color/text_primary"
        android:minHeight="48dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Method &amp; Status"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <Spinner
            android:id="@+id/spEditExpMethod"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:entries="@array/method_options"
            android:backgroundTint="@color/text_primary"/>
        <Spinner
            android:id="@+id/spEditExpStatus"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:entries="@array/payment_statuses"
            android:backgroundTint="@color/text_primary"/>
    </LinearLayout>

</LinearLayout>